<h1><%= title %></h1>
<p>Use this page to manage classification records and inventory records.</p>

<section class="management-links">
  <ul>
    <li><a href="/inv/add-classification" title="Add a new classification">Add New Classification</a></li>
    <li><a href="/inv/add-inventory" title="Add a new inventory item">Add New Inventory Item</a></li>
  </ul>
</section>

<section class="inventory-controls">
  <h2>Inventory Tools</h2>
  <p>Select a classification to review and manage inventory items.</p>
  <label for="classificationList">Choose a classification</label>
  <%- classificationSelect %>
  <table id="inventoryDisplay"></table>
  <noscript>JavaScript must be enabled to use the inventory management table.</noscript>
</section>

<script src="/js/inventory.js"></script>
