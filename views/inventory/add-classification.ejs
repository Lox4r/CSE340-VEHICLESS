<h1><%= title %></h1>
<p>Enter a classification name using letters and numbers only. Spaces and special characters are not allowed.</p>

<% if (errors && errors.length) { %>
  <ul class="notice errors">
    <% errors.forEach((error) => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/inv/add-classification" method="post" class="inventory-form">
  <label for="classification_name">Classification Name</label>
  <input
    type="text"
    id="classification_name"
    name="classification_name"
    required
    pattern="^[A-Za-z0-9]+$"
    title="Use letters and numbers only. No spaces or special characters."
    value="<%= classification_name || '' %>"
  >

  <button type="submit">Add Classification</button>
</form>
